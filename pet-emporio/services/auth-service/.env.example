DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/pe_auth
REDIS_URL=redis://localhost:6380/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY=

# Generate with: openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# true  = OTP printed in terminal (no SMS sent) — use for local dev
# false = OTP sent to real mobile via MSG91
DEV_MODE=true

# MSG91 credentials (only needed when DEV_MODE=false)
# Get these from: https://msg91.com/dashboard
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=PETEMP
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=