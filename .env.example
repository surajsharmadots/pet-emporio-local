# PostgreSQL
# Host port 5433 (5432 is in use by local postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Redis (no credentials for dev)

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# JWT (RS256)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Auth Service
MSG91_AUTH_KEY=your_msg91_auth_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Payment Service (BillDesk)
BILLDESK_MERCHANT_ID=your_merchant_id
BILLDESK_SECRET_KEY=your_secret_key
BILLDESK_BASE_URL=https://uat.billdesk.com

# Notification Service
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
FCM_SERVER_KEY=your_fcm_server_key

# Medical Service (Jitsi)
JITSI_APP_ID=pet-emporio
JITSI_APP_SECRET=your_jitsi_secret

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Zoho Books (Report Service)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=